{
  "name": "@nyantrace/ccaudit",
  "version": "0.1.0",
  "description": "Find where your Claude Code tokens were wasted. Local, offline.",
  "type": "module",
  "bin": {
    "ccaudit": "./dist/cli/index.js"
  },
  "main": "./dist/cli/index.js",
  "files": [
    "dist",
    "fonts",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "bun build src/cli/index.ts --outdir dist/cli --target node --external @resvg/resvg-js --external satori",
    "test": "bun test",
    "lint": "biome check src",
    "dev": "bun run src/cli/index.ts"
  },
  "dependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "chalk": "^5.3.0",
    "cli-table3": "^0.6.5",
    "satori": "^0.26.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "typescript": "^5.8.0",
    "bun-types": "^1.2.0",
    "@biomejs/biome": "^2.0.0"
  },
  "keywords": [
    "claude",
    "claude-code",
    "tokens",
    "cost",
    "audit",
    "anthropic"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nyantrace/ccaudit.git"
  },
  "homepage": "https://github.com/nyantrace/ccaudit",
  "bugs": {
    "url": "https://github.com/nyantrace/ccaudit/issues"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20"
  }
